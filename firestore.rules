rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own profile only.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Whitelist: admin writes via Console or Admin SDK.
    // Read: client-side auth flow uses this for UX (friendly error before sign-up).
    // The beforeUserCreated blocking function is the real enforcement — it cannot be bypassed.
    match /whitelist/{email} {
      allow read: if true;   // Client needs this for pre-check UX
      allow write: if false; // Admin only via Console/Admin SDK
    }
  }
}
