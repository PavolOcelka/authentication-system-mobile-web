# mobile/.env — Expo (local dev)
# Firebase Console → Project Settings → Your apps → Mobile app → SDK setup
# Same Firebase project as web/.env — APP_ID and MEASUREMENT_ID are mobile-specific.

EXPO_PUBLIC_API_KEY=
EXPO_PUBLIC_AUTH_DOMAIN=
EXPO_PUBLIC_PROJECT_ID=
EXPO_PUBLIC_STORAGE_BUCKET=
EXPO_PUBLIC_MESSAGING_SENDER_ID=
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_MEASUREMENT_ID=
